POST http://localhost:3000/users/create-many/
Content-Type: application/json

{
	"users" : [
		{
		"firstName": "Mark",
		"lastName": "Doe",
		"email": "mark@doe.com",
		"password": "password123!"
		},
		{
		"firstName": "Tom",
		"lastName": "Doe",
		"email": "tom@doe.com",
		"password": "password123!"
		}
	]
}

